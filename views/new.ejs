<h1>Створити оголошення</h1>

<form method="POST" action="/announcements">

  <input name="title" placeholder="Коротка назва"
    value="<%= data.title || '' %>">
  <p><%= errors.title %></p>

  <textarea name="description"><%= data.description || '' %></textarea>
  <p><%= errors.description %></p>

  <input name="price" type="number" min="0" step="0.01"
    value="<%= data.price || '' %>">
  <p><%= errors.price %></p>

  <input name="contactInfo" placeholder="Email або телефон"
    value="<%= data.contactInfo || '' %>">
  <p><%= errors.contactInfo %></p>

  <label><input type="radio" name="category" value="sale"
    <%= data.category === 'sale' ? 'checked' : '' %>> Продаж</label>

  <label><input type="radio" name="category" value="service"
    <%= data.category === 'service' ? 'checked' : '' %>> Послуги</label>

  <label><input type="radio" name="category" value="job"
    <%= data.category === 'job' ? 'checked' : '' %>> Робота</label>

  <label><input type="radio" name="category" value="other"
    <%= data.category === 'other' ? 'checked' : '' %>> Інше</label>

  <p><%= errors.category %></p>

  <button type="submit">Опублікувати</button>
</form>

<a href="/">Назад</a>